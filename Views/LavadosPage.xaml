<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarWashFacil.Views.LavadosPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Lavados"
    BackgroundColor="#F3F6FB">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Frame CornerRadius="22"
                   Padding="18"
                   BackgroundColor="#111827"
                   HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Gestión de lavados"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Registra, selecciona y procesa cada servicio."
                           FontSize="14"
                           TextColor="#D1D5DB" />
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Frame Grid.Column="0" CornerRadius="18" BackgroundColor="White">
                    <VerticalStackLayout>
                        <Label Text="Pendientes de hoy" FontAttributes="Bold" TextColor="#374151" />
                        <Label Text="{Binding TotalPendientesHoy}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2563EB" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" CornerRadius="18" BackgroundColor="White">
                    <VerticalStackLayout>
                        <Label Text="Terminados hoy" FontAttributes="Bold" TextColor="#374151" />
                        <Label Text="{Binding TotalTerminadosHoy}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#059669" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame CornerRadius="18"
                   Padding="16"
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nuevo lavado"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1F2937" />

                    <Entry Placeholder="Cliente"
                           Text="{Binding Cliente}" />

                    <Entry Placeholder="Placa"
                           Text="{Binding Placa}" />

                    <Picker Title="Tipo de lavado"
                            ItemsSource="{Binding TiposLavado}"
                            SelectedItem="{Binding TipoLavado}" />

                    <Entry Placeholder="Precio"
                           Keyboard="Numeric"
                           Text="{Binding Precio}" />

                    <Picker Title="Empleado"
                            ItemsSource="{Binding Empleados}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding EmpleadoSeleccionado}" />

                    <Picker Title="Estado"
                            ItemsSource="{Binding Estados}"
                            SelectedItem="{Binding Estado}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Guardar"
                                HeightRequest="48"
                                CornerRadius="14"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                Command="{Binding GuardarLavadoCommand}" />

                        <Button Grid.Column="1"
                                Text="Limpiar"
                                HeightRequest="48"
                                CornerRadius="14"
                                BackgroundColor="#E5E7EB"
                                TextColor="#111827"
                                Command="{Binding LimpiarFormularioCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="18"
                   Padding="16"
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Lavados pendientes"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#1F2937" />
                        <Label Grid.Column="1"
                               Text="{Binding LavadosPendientes.Count, StringFormat='Total: {0}'}"
                               TextColor="#6B7280"
                               VerticalOptions="Center" />
                    </Grid>

                    <Label Text="{Binding DetalleLavadoSeleccionado}"
                           FontSize="13"
                           TextColor="#6B7280" />

                    <Button Text="Marcar como terminado"
                            HeightRequest="48"
                            CornerRadius="14"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            Command="{Binding MarcarTerminadoCommand}" />

                    <Button Text="Cancelar lavado"
                            HeightRequest="48"
                            CornerRadius="14"
                            BackgroundColor="#EF4444"
                            TextColor="White"
                            Command="{Binding CancelarLavadoCommand}" />

                    <CollectionView ItemsSource="{Binding LavadosPendientes}">
                        <CollectionView.EmptyView>
                            <Label Text="No hay lavados pendientes."
                                   HorizontalOptions="Center"
                                   TextColor="Gray"
                                   Margin="0,20,0,0" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="16"
                                       Padding="14"
                                       Margin="0,6"
                                       BackgroundColor="#F9FAFB"
                                       BorderColor="#E5E7EB">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarLavadoCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Cliente}"
                                               FontAttributes="Bold"
                                               FontSize="18"
                                               TextColor="#111827" />

                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Estado}"
                                               TextColor="#2563EB"
                                               FontAttributes="Bold" />

                                        <Label Grid.Row="1" Grid.Column="0"
                                               Text="{Binding Placa, StringFormat='Placa: {0}'}"
                                               TextColor="#4B5563" />

                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Precio, StringFormat='RD${0:F2}'}"
                                               TextColor="#059669"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="End" />

                                        <Label Grid.Row="2" Grid.Column="0"
                                               Text="{Binding TipoLavado, StringFormat='Lavado: {0}'}"
                                               FontSize="13"
                                               TextColor="#6B7280" />

                                        <Label Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Fecha, StringFormat='Fecha: {0:dd/MM/yyyy hh:mm tt}'}"
                                               FontSize="12"
                                               TextColor="#9CA3AF"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="18"
                   Padding="16"
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Lavados terminados de hoy"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#1F2937" />
                        <Label Grid.Column="1"
                               Text="{Binding LavadosTerminadosHoy.Count, StringFormat='Total: {0}'}"
                               TextColor="#6B7280"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding LavadosTerminadosHoy}">
                        <CollectionView.EmptyView>
                            <Label Text="No hay lavados terminados hoy."
                                   HorizontalOptions="Center"
                                   TextColor="Gray"
                                   Margin="0,20,0,0" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="16"
                                       Padding="14"
                                       Margin="0,6"
                                       BackgroundColor="#F0FDF4"
                                       BorderColor="#BBF7D0">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Cliente}"
                                               FontAttributes="Bold"
                                               FontSize="18"
                                               TextColor="#111827" />

                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="Terminado"
                                               TextColor="#059669"
                                               FontAttributes="Bold" />

                                        <Label Grid.Row="1" Grid.Column="0"
                                               Text="{Binding Placa, StringFormat='Placa: {0}'}"
                                               TextColor="#4B5563" />

                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Precio, StringFormat='RD${0:F2}'}"
                                               TextColor="#059669"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="End" />

                                        <Label Grid.Row="2" Grid.Column="0"
                                               Text="{Binding EmpleadoNombre, StringFormat='Empleado: {0}'}"
                                               FontSize="13"
                                               TextColor="#6B7280" />

                                        <Label Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Fecha, StringFormat='Fecha: {0:dd/MM/yyyy hh:mm tt}'}"
                                               FontSize="12"
                                               TextColor="#9CA3AF"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#2563EB"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>