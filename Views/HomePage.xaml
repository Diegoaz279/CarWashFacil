<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarWashFacil.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Inicio"
    BackgroundColor="#F1F5F9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <Border StrokeShape="RoundRectangle 24"
                    Padding="20"
                    Background="#1E293B"
                    Shadow="{Shadow Brush=#000000, Offset='0,8', Opacity=0.3, Radius=12}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="¡Bienvenido!"
                               FontSize="14"
                               TextColor="#64748B" />
                        <Label Text="CarWash Fácil"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="{Binding FechaHoy, StringFormat='{0:dddd, dd MMMM yyyy}'}"
                               FontSize="13"
                               TextColor="#94A3B8"
                               Margin="0,4,0,0" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" 
                           Text="🚿"
                           FontSize="48"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Grid KPIs 2x2 -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Lavados -->
                <Border Grid.Row="0" Grid.Column="0" 
                        StrokeShape="RoundRectangle 20" 
                        Background="White"
                        Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.1, Radius=8}"
                        Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrALavadosCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 12"
                                Background="#DBEAFE"
                                Padding="10"
                                Shadow="{Shadow Brush=Transparent}">
                            <Label Text="🚗"
                                   FontSize="24" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Lavados Hoy" 
                                   FontSize="12" 
                                   TextColor="#64748B"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding LavadosHoy}"
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#2563EB" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Ingresos -->
                <Border Grid.Row="0" Grid.Column="1" 
                        StrokeShape="RoundRectangle 20" 
                        Background="White"
                        Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.1, Radius=8}"
                        Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrACajaCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 12"
                                Background="#D1FAE5"
                                Padding="10"
                                Shadow="{Shadow Brush=Transparent}">
                            <Label Text="💰"
                                   FontSize="24" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Ingresos" 
                                   FontSize="12" 
                                   TextColor="#64748B"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding IngresosHoy, StringFormat='RD${0:N0}'}"
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#10B981" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Gastos -->
                <Border Grid.Row="1" Grid.Column="0" 
                        StrokeShape="RoundRectangle 20" 
                        Background="White"
                        Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.1, Radius=8}"
                        Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrACajaCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 12"
                                Background="#FEE2E2"
                                Padding="10"
                                Shadow="{Shadow Brush=Transparent}">
                            <Label Text="📉"
                                   FontSize="24" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Gastos" 
                                   FontSize="12" 
                                   TextColor="#64748B"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding GastosHoy, StringFormat='RD${0:N0}'}"
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#EF4444" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Balance -->
                <Border Grid.Row="1" Grid.Column="1" 
                        StrokeShape="RoundRectangle 20" 
                        Background="#7C3AED"
                        Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.2, Radius=8}"
                        Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrACajaCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 12"
                                Background="#8B5CF6"
                                Padding="10"
                                Shadow="{Shadow Brush=Transparent}">
                            <Label Text="⚖️"
                                   FontSize="24"
                                   TextColor="White" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Balance" 
                                   FontSize="12" 
                                   TextColor="#DDD6FE"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding BalanceHoy, StringFormat='RD${0:N0}'}"
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="White" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <!-- Acciones Rápidas -->
            <Border StrokeShape="RoundRectangle 20" 
                    Background="White"
                    Shadow="{Shadow Brush=#000000, Offset='0,4', Opacity=0.1, Radius=8}"
                    Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Acciones Rápidas"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1E293B" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="➕ Nuevo Lavado"
                                Command="{Binding IrALavadosCommand}"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="52"
                                FontAttributes="Bold"
                                FontSize="14" />

                        <Button Grid.Column="1"
                                Text="💵 Ver Caja"
                                Command="{Binding IrACajaCommand}"
                                BackgroundColor="#1E293B"
                                TextColor="White"
                                CornerRadius="14"
                                HeightRequest="52"
                                FontAttributes="Bold"
                                FontSize="14" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Estado del sistema -->
            <Border StrokeShape="RoundRectangle 16" 
                    Background="#F0FDF4"
                    Stroke="#86EFAC"
                    Padding="16"
                    Shadow="{Shadow Brush=Transparent}">
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border StrokeShape="RoundRectangle 20"
                            Background="#10B981"
                            WidthRequest="12"
                            HeightRequest="12"
                            Shadow="{Shadow Brush=Transparent}"
                            Padding="0" />
                    <Label Text="Sistema operativo • Todo funciona correctamente"
                           FontSize="13"
                           TextColor="#059669"
                           FontAttributes="Bold" />
                </HorizontalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#2563EB"
                               Scale="0.8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>